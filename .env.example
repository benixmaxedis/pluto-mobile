# Bundled into the app — must use EXPO_PUBLIC_ prefix (see Expo env docs).
# Use the exact "Project URL" from Supabase Dashboard → Settings → API (e.g. https://abcdxyz123.supabase.co).
# A made-up hostname will fail at runtime with a network / fetch error from auth-js.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# New publishable key (sb_publishable_…); replaces the legacy anon key in the client.
# https://github.com/orgs/supabase/discussions/29260
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Legacy JWT anon key — still supported if you have not migrated keys yet.
# EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional — Supabase CLI only (`supabase link -p`). Not read by the Expo app. Never commit a real password.
# SUPABASE_DB_PASSWORD=
